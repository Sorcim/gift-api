# Valeurs locales pour développement avec Docker Compose
# Copier ce fichier en .env.local et adapter les valeurs

# Symfony
APP_ENV=dev
APP_SECRET=un-secret-local-de-32-caracteres-min

# PostgreSQL — doit correspondre aux valeurs dans compose.yaml / compose.override.yaml
POSTGRES_PASSWORD=dev_password_local
POSTGRES_USER=app
POSTGRES_DB=app

# Doctrine (host=db = nom du service Docker)
DATABASE_URL=postgresql://app:dev_password_local@db:5432/app?serverVersion=16&charset=utf8

# Session PDO (format PDO obligatoire, NE PAS utiliser postgresql:// ici)
SESSION_DSN=pgsql:host=db;port=5432;dbname=app;user=app;password=dev_password_local

# CORS — le frontend tourne sur :3000
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Resend (optionnel en dev local)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
